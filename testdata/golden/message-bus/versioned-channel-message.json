{
  "formatVersion": 1,
  "suite": "versioned-channel-message",
  "source": "java-contract",
  "contractEvidence": {
    "approvedOn": "2026-07-15",
    "adr": "docs/adr/0007-use-project-owned-bounded-channel-message-protocol.md",
    "contract": "docs/contracts/versioned-channel-message-runtime.md",
    "spec": "docs/specs/2026-07-15-versioned-channel-message-runtime-design.md"
  },
  "normalization": [
    "schemaVersion 必须精确为 1",
    "入站标识与正文去除首尾空白，出站正文保持原样",
    "标识拒绝 ISO Control 字符",
    "CONTENT_DELTA 保留仅由空白组成的有效增量",
    "失败码决定 retryable，调用方不能自行覆盖"
  ],
  "defaults": {
    "inbound": {
      "schemaVersion": 1,
      "messageId": "msg-001",
      "turnId": "turn-001",
      "sessionId": "cli:demo",
      "channel": "cli",
      "conversationId": "demo",
      "senderId": "local-user",
      "content": "你好",
      "occurredAt": "2026-07-15T00:00:00Z"
    },
    "outbound": {
      "schemaVersion": 1,
      "turnId": "turn-001",
      "sessionId": "cli:demo",
      "channel": "cli",
      "conversationId": "demo",
      "sequence": 0,
      "type": "TURN_STARTED",
      "content": "",
      "code": "",
      "retryable": false
    }
  },
  "cases": [
