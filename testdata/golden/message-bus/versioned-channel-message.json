        "conversationId": "  trimmed  ",
        "senderId": "  local-user  ",
        "content": "  保留正文内部 空格  "
      },
      "expected": {
        "accepted": true,
        "messageId": "msg-002",
        "turnId": "turn-002",
        "sessionId": "cli:trimmed",
        "channel": "cli",
        "conversationId": "trimmed",
