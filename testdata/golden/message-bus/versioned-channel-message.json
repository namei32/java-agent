      "input": {"kind": "inbound"},
      "expected": {
        "accepted": true,
        "messageId": "msg-001",
        "turnId": "turn-001",
        "sessionId": "cli:demo",
        "channel": "cli",
        "conversationId": "demo",
        "senderId": "local-user",
        "content": "你好",
        "occurredAt": "2026-07-15T00:00:00Z"
      }
    },
