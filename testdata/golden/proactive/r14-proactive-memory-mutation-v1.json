  "cases": [
    {
      "id": "no-candidate-creates-no-memory-pending-operation",
      "group": "input",
      "input": {"candidate": "NONE"},
      "expected": {"outcome": "NOT_READY", "createAttempts": 0}
    },
    {
      "id": "expired-candidate-creates-no-memory-pending-operation",
      "group": "lease",
      "input": {"candidate": "READY", "lease": "EXPIRED"},
      "expected": {"outcome": "NOT_READY", "createAttempts": 0}
    },
    {
      "id": "cancelled-candidate-creates-no-memory-pending-operation",
      "group": "cancellation",
      "input": {"candidate": "READY", "cancel": "BEFORE"},
      "expected": {"outcome": "CANCELLED", "createAttempts": 0}
    },
    {
      "id": "ready-candidate-creates-approved-memory-pending-operation",
      "group": "creation",
      "input": {"candidate": "READY"},
      "expected": {"outcome": "PENDING", "createAttempts": 1, "state": "PENDING_APPROVAL"}
    },
    {
      "id": "candidate-can-create-only-one-memory-pending-operation",
      "group": "idempotency",
      "input": {"candidate": "READY", "repeat": true},
      "expected": {"outcome": "ALREADY_PREPARED", "firstOutcome": "PENDING", "createAttempts": 1}
    },
    {
      "id": "failed-store-releases-candidate-for-safe-memory-retry",
      "group": "failure",
      "input": {"candidate": "READY", "store": "FAIL_ONCE"},
      "expected": {"outcome": "PENDING", "createAttempts": 2}
    },
    {
      "id": "memory-pending-projection-never-renders-source-or-scope",
      "group": "projection",
      "input": {"candidate": "READY"},
      "expected": {"outcome": "PENDING", "createAttempts": 1, "leaksSourceText": false}
    }
  ]
